[Unit]
Description=DaybreakOS shell (cage + Firefox kiosk)
After=systemd-user-sessions.service seatd.service aurorad.service
Wants=aurorad.service
Requires=seatd.service
Conflicts=getty@tty1.service

[Service]
User=aurora
Group=aurora
PAMName=login
TTYPath=/dev/tty1
StandardInput=tty
StandardOutput=journal
StandardError=journal
UtmpIdentifier=tty1
ExecStart=/usr/bin/aurora-session
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
